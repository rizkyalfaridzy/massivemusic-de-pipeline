# ---- DSP API credentials -------------------------------------------------
# Spotify: https://developer.spotify.com/dashboard  (create an app)
# NOTE: since Feb 2026 Spotify requires the app OWNER to have Premium, even for
# search/metadata. If you don't, leave these blank (or keep them) — the pipeline
# auto-falls back to MusicBrainz (free, no account) for ISRCs.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# YouTube Data API v3: https://console.cloud.google.com/apis/credentials  (API key)
# Free: 10,000 quota units/day, no credit card.
YOUTUBE_API_KEY=

# ---- ISRC source ---------------------------------------------------------
# auto | spotify | musicbrainz
#   auto        -> use Spotify if its credentials work, else MusicBrainz (free)
#   musicbrainz -> always use MusicBrainz (free, no account, slower ~1 req/sec)
#   spotify     -> force Spotify (mock data if no/invalid credentials)
ISRC_SOURCE=auto

# ---- Tunables ------------------------------------------------------------
# How many catalog songs to process per run. The full catalog (698 songs)
# exceeds free quotas (YouTube 100 units/song => ~100/day; MusicBrainz ~1 req/s),
# so we cap per run and process incrementally. 30 is a good demo size.
MAX_SONGS=30

# NOTE: If YouTube key is blank, that source runs in MOCK mode so you can still
# demo the full pipeline end-to-end without API access.
